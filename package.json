{
  "name": "sarasti",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/sarasti.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/sarasti.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "public/data/*.bin"
  ],
  "scripts": {
    "dev": "vite",
    "dev:hormuz": "vite",
    "type-check": "tsc --noEmit",
    "build": "tsc -b && vite build",
    "build:lib": "vite build --config vite.lib.config.ts",
    "build:check": "npm run type-check && npm test && npm run build:lib",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "deploy": "wrangler deploy",
    "deploy:preview": "wrangler deploy --env preview",
    "wrangler": "wrangler",
    "pull-data": "python tools/pull_market_data.py && python tools/pull_gdelt.py",
    "extract-flame": "python tools/extract_flame.py",
    "visual-check": "tsx tools/visual-check.ts"
  },
  "peerDependencies": {
    "three": ">=0.160.0",
    "zustand": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "zustand": { "optional": true }
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "three": "^0.172.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260317.1",
    "@playwright/test": "^1.50.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.5.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/three": "^0.172.0",
    "@vitejs/plugin-react": "^4.3.0",
    "jsdom": "^29.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vite": "^6.2.0",
    "vitest": "^3.0.0",
    "wrangler": "^4.74.0"
  }
}
